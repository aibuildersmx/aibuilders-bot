# WhatsApp Bot Config
BOT_NAME=bot
BOT_ALIASES=bot,aibot

# Group JIDs to allow (get from logs after connecting)
ALLOWED_GROUPS=

# Group name mapping — format: jid1:name1,jid2:name2
GROUP_NAMES=

# DM JIDs allowed for testing
TEST_DM_JIDS=

# User phone numbers to allow (empty = everyone)
ALLOWED_USERS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=10
GROUP_COOLDOWN_MS=5000

# Pi SDK
PI_AGENT_DIR=/data/agent
PI_CWD=/data
PI_SESSIONS_DIR=/data/sessions

# Baileys auth persistence
BAILEYS_AUTH_DIR=/data/baileys-auth

# Auth (paste the full JSON from auth.json)
BOT_AUTH_JSON=

# Tool API keys
BRAVE_API_KEY=
FIRECRAWL_API_KEY=

# Railway
PORT=3000
